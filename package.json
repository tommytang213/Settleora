{
  "name": "settleora-scaffold",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "validate": "npm run validate:scaffold && npm run validate:openapi && npm run validate:api && npm run validate:compose && npm run validate:api-docker",
    "validate:scaffold": "node tools/validate-scaffold.mjs",
    "validate:openapi": "redocly lint packages/contracts/openapi/settleora.v1.yaml",
    "validate:api": "dotnet test services/api/Settleora.Api.sln",
    "validate:compose": "docker compose --env-file infra/env/.env.example -f infra/docker-compose.yml config",
    "validate:api-docker": "docker compose --env-file infra/env/.env.example -f infra/docker-compose.yml build api",
    "validate:api-runtime": "node tools/validate-api-runtime.mjs",
    "validate:api-migrations": "node tools/validate-api-migrations.mjs"
  },
  "devDependencies": {
    "@redocly/cli": "^2.30.1",
    "yaml": "^2.8.3"
  }
}
