{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Settleora": {
    "Auth": {
      "PasswordHashing": {
        "Algorithm": "argon2id",
        "PolicyVersion": "argon2id-v1",
        "Argon2idIterations": 3,
        "Argon2idMemorySizeBytes": 67108864,
        "VerifierMaxLength": 512,
        "ParametersMaxLength": 1024
      },
      "Sessions": {
        "CurrentAccessSessionDefaultLifetime": "08:00:00",
        "CurrentAccessSessionMaxLifetime": "30.00:00:00",
        "RefreshAccessSessionDefaultLifetime": "00:15:00",
        "RefreshAccessSessionMaxLifetime": "00:30:00",
        "RefreshIdleTimeout": "7.00:00:00",
        "RefreshAbsoluteLifetime": "30.00:00:00",
        "ClockSkewAllowance": "00:02:00"
      }
    },
    "Database": {
      "ConnectionString": ""
    },
    "RabbitMq": {
      "HostName": "",
      "Port": 5672,
      "UserName": "",
      "Password": "",
      "VirtualHost": "/"
    },
    "Storage": {
      "Provider": "Local",
      "RootPath": ""
    }
  }
}
