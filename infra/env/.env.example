# Settleora local development example environment.
# Do not commit real secrets.
# Copy this file to a local .env file when needed.
# This file is only for local development examples.

POSTGRES_DB=settleora
POSTGRES_USER=settleora
POSTGRES_PASSWORD=settleora_dev_password

RABBITMQ_DEFAULT_USER=settleora
RABBITMQ_DEFAULT_PASS=settleora_dev_password

SETTLEORA_STORAGE_PROVIDER=Local
SETTLEORA_STORAGE_ROOT=./data/storage
SETTLEORA_ENVIRONMENT=Development
SETTLEORA_API_HTTP_PORT=8080
